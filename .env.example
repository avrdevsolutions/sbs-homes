# =============================================================================
# Environment Variables Template
# =============================================================================
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file containing secrets.
#
# See docs-v2/adrs/0006-environment.md for the full strategy.
# =============================================================================

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
# The base URL of the application (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment name (development, staging, production)
NEXT_PUBLIC_APP_ENV=development

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Internal API base URL (for server-side fetches, can be internal network)
API_BASE_URL=http://localhost:3000/api

# External API base URL (if consuming third-party APIs)
# EXTERNAL_API_URL=https://api.example.com
# EXTERNAL_API_KEY=your-api-key-here

# -----------------------------------------------------------------------------
# Database (uncomment when adding database)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb?schema=public

# -----------------------------------------------------------------------------
# Authentication (uncomment when adding auth)
# -----------------------------------------------------------------------------
# AUTH_SECRET=generate-a-32-char-secret-here
# AUTH_URL=http://localhost:3000

# OAuth providers (uncomment as needed)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Third-party Services (uncomment as needed)
# -----------------------------------------------------------------------------
# Monitoring / Error tracking
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_POSTHOG_KEY=

# Email
# RESEND_API_KEY=
# EMAIL_FROM=noreply@example.com

# File storage
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Feature Flags (optional)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_FEATURE_NEW_DASHBOARD=false

