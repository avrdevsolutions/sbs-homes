{
  "name": "Section",
  "pattern": "record-map",
  "forwardRef": false,
  "polymorphic": false,
  "variantAxes": {
    "spacing": ["none", "compact", "standard", "spacious", "hero"],
    "background": ["default", "warm", "warm-alt", "dark", "dark-deeper"],
    "containerSize": ["sm", "md", "lg", "xl", "full"],
    "containerPadding": ["none", "tight", "default", "wide"]
  },
  "nativeProps": true,
  "props": ["fullBleed"],
  "defaults": {
    "spacing": "standard",
    "background": "default",
    "containerSize": "xl",
    "containerPadding": "default",
    "fullBleed": false
  },
  "exports": ["Section"]
}
